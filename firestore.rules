rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default safety net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role == 'citizen' &&
             data.createdAt == request.time;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'location', 'status', 'authorId', 'createdAt']) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             data.description is string && data.description.size() >= 1 && data.description.size() <= 2000 &&
             data.category is string && data.category.size() >= 1 && data.category.size() <= 100 &&
             data.location is map &&
             data.status == 'submitted' &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isVerified() && isValidUser(incoming());
      allow update: if (isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']) &&
                      incoming().updatedAt == request.time) || isAdmin();
    }

    match /reports/{reportId} {
      // Publicly viewable, but only owners/admins see full author details if we added any.
      allow read: if true; 
      
      allow create: if isVerified() && isValidId(reportId) && isValidReport(incoming());
      
      allow update: if (
        // Action: Citizen edit (only if not yet reviewed)
        (isOwner(existing().authorId) && 
         existing().status == 'submitted' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'location', 'updatedAt']) &&
         incoming().updatedAt == request.time)
        ||
        // Action: Admin update (status, timeline, response)
        (isAdmin() && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'timeline', 'officialResponse', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
      
      allow delete: if isAdmin();
    }

    match /admins/{adminUid} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
